# Copy this file to `.env.openrouter` and fill in your OpenRouter API key.
# `.env.openrouter` is gitignored.
#
# Get a key at https://openrouter.ai/keys
# Stages using OpenRouter: 1 (some layers), 2 (recipes), 2b (nutrition,
# planned), 3 (LCA), 5 (phylogeny, planned). See README.md "Models per
# stage" for which models each stage hits.
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Optional: HuggingFace token to avoid anonymous-download rate limits on
# first use of sentence-transformer models. Get one at
# https://huggingface.co/settings/tokens (read-only is fine).
# HF_TOKEN=hf_REPLACE_ME
